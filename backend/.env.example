# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_MS=604800000

# CORS
CORS_ORIGIN=http://localhost:3000

# Database
DB_PATH=./data/vaultlock.db

# Argon2id KDF
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# Rate Limiting
RATE_LIMIT_AUTH=5
RATE_LIMIT_AUTH_WINDOW=900000
RATE_LIMIT_VAULT=30
RATE_LIMIT_VAULT_WINDOW=60000
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_DEFAULT_WINDOW=60000

# TOTP
TOTP_ENABLED=true

# CSRF
CSRF_SECRET=change-this-to-a-random-secret

# Email 2FA
EMAIL_2FA_ENABLED=true
EMAIL_2FA_CODE_LENGTH=6
EMAIL_2FA_CODE_EXPIRY_MS=300000
EMAIL_2FA_COOLDOWN_MS=30000

# SMTP (leave empty to use JSON transport — emails logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vaultlock.app
